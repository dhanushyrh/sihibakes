# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: for `npm run db:migrate` (from Supabase → Database → Connection string)
DATABASE_URL=postgresql://postgres.ustdcoptfypawengsfya:uKihkGc4aQ3c6fi4@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Map ID for Advanced Markers (create in Google Cloud Console; DEMO_MAP_ID works for local dev)
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=

# Optional: salt for hashing activity IP addresses in analytics
ACTIVITY_IP_HASH_SALT=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Borzo delivery (test: robotapitest-in.borzodelivery.com)
BORZO_AUTH_TOKEN=
BORZO_API_BASE_URL=https://robotapitest-in.borzodelivery.com/api/business/1.8
# Default vehicle type 8 = Motorbike (two-wheeler, up to 20 kg)
BORZO_VEHICLE_TYPE_ID=8

NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp Cloud API (optional — leave blank to use on-screen verification codes)
# WHATSAPP_WABA_ID: WhatsApp Business Account ID (required for template create/list API)
# Access token needs whatsapp_business_messaging (send) + whatsapp_business_management (templates)
WHATSAPP_WABA_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_LANGUAGE_CODE=en_US

# Template names (Utility unless noted)
# checkout_otp (Authentication): body "{{1}}" + copy-code button
# jaspers_market_order_confirmation_v1 (Meta test): body {{1}} name, {{2}} order id, {{3}} delivery date
WHATSAPP_TEMPLATE_ORDER_PLACED=jaspers_market_order_confirmation_v1
WHATSAPP_TEMPLATE_ORDER_PLACED_LANGUAGE=en_US
# order_confirmed: Hi {{1}}! Order {{2}} confirmed. Total {{3}}. Delivery {{4}}.
# order_status_update: Order {{1}} — {{2}}. {{3}}
# order_out_for_delivery_v2: Order {{1}} out for delivery. Partner {{2}}. Reference {{3}}. ETA {{4}}.
# order_cancelled: Order {{1}} cancelled. Reason {{2}}.
WHATSAPP_TEMPLATE_OTP=checkout_otp
WHATSAPP_TEMPLATE_ORDER_CONFIRMED=order_confirmed
WHATSAPP_TEMPLATE_ORDER_STATUS=order_status_update
WHATSAPP_TEMPLATE_ORDER_DISPATCH=order_out_for_delivery_v2
WHATSAPP_TEMPLATE_ORDER_CANCELLED=order_cancelled

# Webhook + two-way chat (required for inbound messages)
# Callback URL: https://your-domain.com/api/whatsapp/webhook
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Welcome auto-reply when a customer opens the 24-hour service window
WHATSAPP_AUTO_REPLY_ENABLED=true
# Optional — defaults to https://sihibakes.in/orders (or NEXT_PUBLIC_APP_URL/orders locally)
WHATSAPP_AUTO_REPLY_STORE_URL=https://sihibakes.in/orders

# Admin alerts (optional — in-app alerts always work when Supabase is configured)
# Recipient for alert emails
ADMIN_ALERT_EMAIL=
# Gmail SMTP (use an App Password: Google Account → Security → 2-Step Verification → App passwords)
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_FROM_NAME=Sihi Bakes
